<?xml version="1.0" encoding="utf-8"?>
<SiPolicy xmlns="urn:schemas-microsoft-com:sipolicy" PolicyType="Base Policy">
  <VersionEx>1.0.0.0</VersionEx>
  <PlatformID>{2E07F7E4-194C-4D20-B7C9-6F44A6C5A234}</PlatformID>
  <PolicyID>{A1B2C3D4-E5F6-7890-ABCD-EF0123456789}</PolicyID>
  <BasePolicyID>{A1B2C3D4-E5F6-7890-ABCD-EF0123456789}</BasePolicyID>
  <Rules>
    <Rule>
      <Option>Enabled:Unsigned System Integrity Policy</Option>
    </Rule>
    <Rule>
      <Option>Enabled:Audit Mode</Option>
    </Rule>
    <Rule>
      <Option>Enabled:Advanced Boot Options Menu</Option>
    </Rule>
    <Rule>
      <Option>Required:Enforce Store Applications</Option>
    </Rule>
    <Rule>
      <Option>Enabled:UMCI</Option>
    </Rule>
    <Rule>
      <Option>Enabled:Inherit Default Policy</Option>
    </Rule>
  </Rules>
  
  <!--EKUS-->
  <EKUs />
  <FileRules>
    <!--Allow all files in Program Files directories-->
    <Allow ID="ID_ALLOW_PROGRAM_FILES_X86" FriendlyName="Allow Program Files (x86)" FilePath="%PROGRAMFILES(X86)%\*" />
    <Allow ID="ID_ALLOW_PROGRAM_FILES" FriendlyName="Allow Program Files" FilePath="%PROGRAMFILES%\*" />
    
    <!--Allow all Microsoft signed files-->
    <Allow ID="ID_ALLOW_MSFT" FriendlyName="Allow Microsoft files" FileName="*" />
    
    <!--Deny all files in Downloads folder-->
    <Deny ID="ID_DENY_DOWNLOADS" FriendlyName="Deny Downloads folder" FilePath="%OSDRIVE%\Users\*\Downloads\*" />
    
    <!--Deny all executables in ossec-agent active-response bin folder-->
    <Deny ID="ID_DENY_OSSEC_BIN" FriendlyName="Deny OSSEC agent bin folder" FilePath="C:\Program Files (x86)\ossec-agent\active-response\bin\*" />
  </FileRules>

  <!--Signers-->
  <Signers>
    <!--Microsoft Signers-->
    <Signer Name="Microsoft Code Signing" ID="ID_SIGNER_MICROSOFT">
      <CertRoot Type="TBS" Value="F6F717A43AD9ABDDC8CEFDDE1C505462535E7D1307E630F31B560C1FF5EED7D3" />
      <CertPublisher Value="Microsoft Corporation" />
    </Signer>
    <Signer Name="Microsoft Product Root 2010" ID="ID_SIGNER_MICROSOFT_ROOT_2010">
