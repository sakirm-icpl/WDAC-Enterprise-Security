  <!--Signing Scenarios-->
  <SigningScenarios>
    <SigningScenario Value="131" ID="ID_SIGNINGSCENARIO_UMCI">
      <ProductSigners>
        <AllowedSigners>
          <AllowedSigner SignerId="ID_SIGNER_MICROSOFT" />
          <AllowedSigner SignerId="ID_SIGNER_MICROSOFT_ROOT_2010" />
          <AllowedSigner SignerId="ID_SIGNER_MICROSOFT_ROOT_1997" />
          <AllowedSigner SignerId="ID_SIGNER_MICROSOFT_ROOT_PCA_2011" />
