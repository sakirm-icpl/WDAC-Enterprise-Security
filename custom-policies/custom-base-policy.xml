    <Signer Name="Microsoft Product Root PCA 2011" ID="ID_SIGNER_MICROSOFT_ROOT_PCA_2011">
      <CertRoot Type="TBS" Value="7A8F949B85447C7433BA9BB43773511D3437C445B01B2541875557B8836EC771" />
    </Signer>
    <Signer Name="Microsoft Standard Root CA 2011" ID="ID_SIGNER_MICROSOFT_STANDARD_2011">
      <CertRoot Type="TBS" Value="BCDD55967499119773242E25E5549858F39162F2149DB5BB9349425FBAA971B0" />
