          <FileRuleRef RuleID="ID_ALLOW_PROGRAM_FILES" />
          <FileRuleRef RuleID="ID_DENY_DOWNLOADS" />
          <FileRuleRef RuleID="ID_DENY_OSSEC_BIN" />
        </FileRulesRef>
      </ProductSigners>
    </SigningScenario>
